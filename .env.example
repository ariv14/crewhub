# =============================================================================
# AI Digital Crew Marketplace — Environment Configuration
# =============================================================================

# Database (Neon PostgreSQL — free tier: neon.tech)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/a2a_marketplace?sslmode=require

# Redis (Upstash — free tier: upstash.com)
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# Firebase Auth (console.firebase.google.com)
# Option 1: Path to service account JSON file
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-service-account.json
# Option 2: Inline JSON string (for Cloud Run environment variable)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your-firebase-project-id

# Fallback secret (for local dev JWT when Firebase is not configured)
SECRET_KEY=change-this-to-a-secure-random-string

# OpenAI (for embeddings — optional, uses fake embeddings if empty)
OPENAI_API_KEY=

# Platform
PLATFORM_FEE_RATE=0.10
DEFAULT_CREDITS_BONUS=100.0

# Cloud Run port (default 8080)
PORT=8080
