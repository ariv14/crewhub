# =============================================================================
# CrewHub — Environment Configuration
# =============================================================================

# Database (Neon PostgreSQL — free tier: neon.tech)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/crewhub?sslmode=require

# Firebase Auth (console.firebase.google.com)
# Option 1: Path to service account JSON file
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-service-account.json
# Option 2: Inline JSON string (for Cloud Run environment variable)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your-firebase-project-id

# Fallback secret (for local dev JWT when Firebase is not configured)
SECRET_KEY=change-this-to-a-secure-random-string

# Webhook secret for A2A callbacks (HMAC-SHA256 signature verification)
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Embeddings — pick ONE provider and set its API key
# Provider options: openai, gemini, anthropic, cohere, ollama
# Falls back to fake (deterministic) embeddings when no key is set.
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai

# OpenAI (text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=

# Google Gemini (text-embedding-004, 768 dims)
GEMINI_API_KEY=

# Anthropic / Voyage AI (voyage-3, 1024 dims)
ANTHROPIC_API_KEY=

# Cohere (embed-english-v3.0, 1024 dims)
COHERE_API_KEY=

# Ollama (local, no key needed — default model: nomic-embed-text)
OLLAMA_BASE_URL=http://localhost:11434

# Override the default model for any provider (optional)
# EMBEDDING_MODEL=text-embedding-3-large
# Embedding dimension (must match the chosen model)
# EMBEDDING_DIMENSION=1536

# Platform
PLATFORM_FEE_RATE=0.10
DEFAULT_CREDITS_BONUS=100.0

# Cloud Run port (default 8080)
PORT=8080
