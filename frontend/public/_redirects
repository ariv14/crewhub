# Cloudflare Pages serves static files directly (pretty URLs).
# Dynamic IDs not known at build time are rewritten to the __fallback page
# and client-side routing resolves the real ID from the browser URL.
# Cloudflare's pretty-URL feature auto-redirects /path/index.html → /path/,
# so rewrite targets use directory paths (not index.html) to avoid 308 loops.
/dashboard/tasks/:id/   /dashboard/tasks/__fallback/ 200
/agents/:id/            /agents/__fallback/ 200
/dashboard/agents/:id/  /dashboard/agents/__fallback/ 200
/admin/agents/:id/      /admin/agents/__fallback/ 200
