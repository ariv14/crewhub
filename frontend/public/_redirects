# Cloudflare Pages: Dynamic IDs not known at build time are rewritten to
# the __fallback page. Client-side JS extracts the real ID from the URL.
#
# IMPORTANT: Only use 200 (rewrite) rules here — NOT 301 redirects.
# Cloudflare 301s take priority over static files, which would catch
# Next.js RSC data files (index.txt, __next._tree.txt) and break
# client-side navigation.
#
# NOTE: _redirects rules fire BEFORE static file lookup, so known
# static sub-routes (like /new/) must be listed explicitly before
# the :id splat to prevent them being caught by the catch-all.
#
# With trailingSlash: true, all client-side links include trailing slashes.
# Both with and without trailing slash variants are needed — external links
# (shared URLs, bookmarks) often omit the trailing slash.
/dashboard/tasks/new        /dashboard/tasks/new/ 200
/dashboard/tasks/new/       /dashboard/tasks/new/ 200
/dashboard/workflows/new    /dashboard/workflows/new/ 200
/dashboard/workflows/new/   /dashboard/workflows/new/ 200
/agents/:id                 /agents/__fallback/ 200
/agents/:id/                /agents/__fallback/ 200
/dashboard/tasks/:id        /dashboard/tasks/__fallback/ 200
/dashboard/tasks/:id/       /dashboard/tasks/__fallback/ 200
/dashboard/agents/:id       /dashboard/agents/__fallback/ 200
/dashboard/agents/:id/      /dashboard/agents/__fallback/ 200
/dashboard/crews/:id        /dashboard/crews/__fallback/ 200
/dashboard/crews/:id/       /dashboard/crews/__fallback/ 200
/dashboard/workflows/:id    /dashboard/workflows/__fallback/ 200
/dashboard/workflows/:id/   /dashboard/workflows/__fallback/ 200
/community-agents/:id       /community-agents/__fallback/ 200
/community-agents/:id/      /community-agents/__fallback/ 200
/admin/agents/:id           /admin/agents/__fallback/ 200
/admin/agents/:id/          /admin/agents/__fallback/ 200
